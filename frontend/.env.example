# Backend URL (DO NOT MODIFY - Pre-configured)
REACT_APP_BACKEND_URL=https://adautomation.preview.emergentagent.com

# EmailJS Configuration (FREE Service)
# Sign up at https://www.emailjs.com/ and get your credentials
# See EMAILJS_SETUP_GUIDE.md for detailed instructions

REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here

# How to get these values:
# 1. PUBLIC_KEY: EmailJS Dashboard → Account → General → Public Key
# 2. SERVICE_ID: EmailJS Dashboard → Email Services → Your Service → Service ID
# 3. TEMPLATE_ID: EmailJS Dashboard → Email Templates → Your Template → Template ID